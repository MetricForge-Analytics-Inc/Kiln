cubes:
  - name: tickets_case_created_time
    sql_table: {{ project_slug }}.support.tickets_details_view

    joins: []

    dimensions:
      - name: case_id
        sql: "CAST({CUBE}.case_id AS VARCHAR)"
        type: string
        primary_key: true
        shown: true

      - name: case_assigned_group_stations
        sql: "CAST({CUBE}.case_assigned_group_stations AS INTEGER)"
        type: number

      - name: case_assignee_stations
        sql: "CAST({CUBE}.case_assignee_stations AS INTEGER)"
        type: number

      - name: case_number_of_reopens
        sql: "CAST({CUBE}.case_number_of_reopens AS INTEGER)"
        type: number

      - name: case_number_of_replies
        sql: "CAST({CUBE}.case_number_of_replies AS INTEGER)"
        type: number

      - name: case_on_hold_minutes_business
        sql: "CAST({CUBE}.case_on_hold_minutes_business AS INTEGER)"
        type: number

      - name: case_on_hold_minutes_calendar
        sql: "CAST({CUBE}.case_on_hold_minutes_calendar AS INTEGER)"
        type: number

      - name: case_organization_id
        sql: "CAST({CUBE}.case_organization_id AS VARCHAR)"
        type: string

      - name: case_reply_time_in_minutes_business
        sql: "CAST({CUBE}.case_reply_time_in_minutes_business AS INTEGER)"
        type: number

      - name: case_reply_time_in_minutes_calendar
        sql: "CAST({CUBE}.case_reply_time_in_minutes_calendar AS INTEGER)"
        type: number

      - name: case_current_status
        sql: case_current_status
        type: string

      - name: case_description
        sql: case_description
        type: string

      - name: case_has_incidents
        sql: case_has_incidents
        type: boolean

      - name: case_is_public
        sql: case_is_public
        type: boolean

      - name: case_priority
        sql: case_priority
        type: string

      - name: case_satisfaction_rating
        sql: case_satisfaction_rating
        type: string

      - name: case_subject
        sql: case_subject
        type: string

      - name: case_tags
        sql: "CAST({CUBE}.case_tags AS VARCHAR)"
        type: string

      - name: case_topic
        sql: case_topic
        type: string

      - name: case_type
        sql: case_type
        type: string

      - name: channel
        sql: channel
        type: string

      - name: assignee
        sql: "CAST({CUBE}.assignee AS VARCHAR)"
        type: string

      - name: requester
        sql: "CAST({CUBE}.requester AS VARCHAR)"
        type: string

      - name: submitter
        sql: "CAST({CUBE}.submitter AS VARCHAR)"
        type: string

      - name: case_created_time
        sql: case_created_time
        type: time

      - name: case_assignee_last_updated_time
        sql: case_assignee_last_updated_time
        type: time

      - name: case_custom_status_updated_time
        sql: case_custom_status_updated_time
        type: time

      - name: case_last_updated_time
        sql: case_last_updated_time
        type: time

      - name: case_requester_last_updated_time
        sql: case_requester_last_updated_time
        type: time

      - name: case_status_last_updated_time
        sql: case_status_last_updated_time
        type: time

      - name: case_initial_assignment_time
        sql: case_initial_assignment_time
        type: time

      - name: case_last_assignment_time
        sql: case_last_assignment_time
        type: time

      - name: case_latest_comment_added_time
        sql: case_latest_comment_added_time
        type: time

    measures:
      - name: case_created_volume
        type: count

      - name: case_end_user_created_volume
        sql: "CASE WHEN {CUBE}.submitter.submitter_role = 'end-user' THEN 1 ELSE 0 END"
        type: sum

      - name: case_agent_created_volume
        sql: "CASE WHEN {CUBE}.submitter.submitter_role != 'end-user' THEN 1 ELSE 0 END"
        type: sum

      - name: case_unsolved_volume
        description: Running total of tickets that are currently unsolved.
        sql: "CASE WHEN {CUBE}.case_current_status NOT IN ('solved', 'closed') THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: total_unreplied_tickets
        description: Running total of tickets with zero agent replies.
        sql: "CASE WHEN {CUBE}.case_number_of_replies < 1 THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: good_satisfaction_tickets
        sql: "CASE WHEN {CUBE}.case_satisfaction_rating = 'good' THEN 1 ELSE 0 END"
        type: sum

      - name: bad_satisfaction_tickets
        sql: "CASE WHEN {CUBE}.case_satisfaction_rating = 'bad' THEN 1 ELSE 0 END"
        type: sum

      - name: rated_satisfaction_tickets
        sql: "CASE WHEN {CUBE}.case_satisfaction_rating IN ('good', 'bad') THEN 1 ELSE 0 END"
        type: sum

      - name: surveyed_satisfaction_tickets
        sql: "CASE WHEN {CUBE}.case_satisfaction_rating IN ('offered', 'good', 'bad') THEN 1 ELSE 0 END"
        type: sum

      - name: unsurveyed_satisfaction_tickets
        sql: "CASE WHEN {CUBE}.case_satisfaction_rating = 'unoffered' THEN 1 ELSE 0 END"
        type: sum

      - name: total_on_hold_time_calendar_minutes
        sql: "CAST({CUBE}.case_on_hold_minutes_calendar AS INTEGER)"
        type: sum

      - name: total_on_hold_time_business_minutes
        sql: "CAST({CUBE}.case_on_hold_minutes_business AS INTEGER)"
        type: sum

      - name: new_tickets
        sql: "CASE WHEN {CUBE}.case_current_status = 'new' THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: open_tickets
        sql: "CASE WHEN {CUBE}.case_current_status = 'open' THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: pending_tickets
        sql: "CASE WHEN {CUBE}.case_current_status = 'pending' THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: on_hold_tickets
        sql: "CASE WHEN {CUBE}.case_current_status = 'hold' THEN 1 ELSE 0 END"
        type: sum
        rolling_window:
          trailing: unbounded

      - name: unassigned_unsolved_tickets
        sql: >-
          CASE WHEN {CUBE}.assignee IS NULL
            AND {CUBE}.case_current_status NOT IN ('solved', 'closed')
            THEN 1 ELSE 0 END
        type: sum
        rolling_window:
          trailing: unbounded

      - name: assigned_unsolved_tickets
        sql: >-
          CASE WHEN {CUBE}.assignee IS NOT NULL
            AND {CUBE}.case_current_status NOT IN ('solved', 'closed')
            THEN 1 ELSE 0 END
        type: sum
        rolling_window:
          trailing: unbounded

      - name: unreplied_unsolved_tickets
        sql: >-
          CASE WHEN {CUBE}.case_number_of_replies < 1
            AND {CUBE}.case_current_status NOT IN ('solved', 'closed')
            THEN 1 ELSE 0 END
        type: sum
        rolling_window:
          trailing: unbounded

      - name: satisfaction_score
        type: number
        sql: "{good_satisfaction_tickets} * 1.0 / NULLIF({rated_satisfaction_tickets}, 0)"

      - name: satisfaction_rated_pct
        type: number
        sql: "{rated_satisfaction_tickets} * 1.0 / NULLIF({surveyed_satisfaction_tickets}, 0)"

      - name: satisfaction_surveyed_pct
        type: number
        sql: "{surveyed_satisfaction_tickets} * 1.0 / NULLIF({case_created_volume}, 0)"

    pre_aggregations: []
