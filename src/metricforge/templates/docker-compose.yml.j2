# {{ project_name }} — Docker Compose
# Generated by MetricForge Kiln v{{ kiln_version }}

services:
  orchestration:
    build:
      context: .
      dockerfile: Orchestration/Dockerfile
    container_name: {{ project_slug }}_orchestration
    env_file: .env
    volumes:
      - postgres_data:/postgres_data
{% if dw_type == 'duckdb_local' %}
      - db_data:/app/db
{% endif %}
    networks:
      - {{ project_slug }}_net
    healthcheck:
      test: ["CMD", "python", "-c", "import sys; sys.exit(0)"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    restart: unless-stopped

{% if sl_type == 'cube_oss' %}
  cube:
    image: cubejs/cube:v1.3
    container_name: {{ project_slug }}_cube
    ports:
      - "4000:4000"
      - "15432:15432"
    env_file: .env
    environment:
      - CUBEJS_DEV_MODE=true
{% if dw_type == 'duckdb_local' %}
      - CUBEJS_DB_TYPE=duckdb
      - CUBEJS_DB_DUCKDB_DATABASE_PATH=/cube/db/metricforge.duckdb
{% elif dw_type == 'motherduck' %}
      - CUBEJS_DB_TYPE=duckdb
{% elif dw_type == 'snowflake' %}
      - CUBEJS_DB_TYPE=snowflake
{% elif dw_type == 'bigquery' %}
      - CUBEJS_DB_TYPE=bigquery
{% endif %}
    volumes:
      - ./Semantic-Cubes/model:/cube/conf/model:ro
{% if dw_type == 'duckdb_local' %}
      - db_data:/cube/db:ro
{% endif %}
    networks:
      - {{ project_slug }}_net
    depends_on:
      orchestration:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:4000/readyz"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    restart: unless-stopped

{% endif %}
  visualization:
    build:
      context: .
      dockerfile: Visualization/Dockerfile
    container_name: {{ project_slug }}_visualization
    ports:
      - "3000:3000"
    env_file: .env
    networks:
      - {{ project_slug }}_net
    depends_on:
      orchestration:
        condition: service_healthy
{% if sl_type == 'cube_oss' %}
      cube:
        condition: service_healthy
{% endif %}
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3000"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    restart: unless-stopped

volumes:
  postgres_data:
{% if dw_type == 'duckdb_local' %}
  db_data:
{% endif %}

networks:
  {{ project_slug }}_net:
    driver: bridge
