import argparse
import json
import subprocess
import sys
import time
from pathlib import Path

from prefect import flow, task, get_run_logger


def _workspace_root() -> Path:
    """Resolve the workspace root (parent of Orchestration/)."""
    return Path(__file__).resolve().parent.parent


def _run(cmd: str, cwd: Path | None = None) -> dict:
    """Run a shell command, raising on failure. Returns timing metrics."""
    logger = get_run_logger()
    logger.info("Running: %s", cmd)
    t0 = time.monotonic()
    result = subprocess.run(cmd, shell=True, cwd=cwd, capture_output=True, text=True)
    elapsed = time.monotonic() - t0
    if result.stdout:
        logger.info(result.stdout)
    if result.stderr:
        logger.warning(result.stderr)
    result.check_returncode()
    return {"command": cmd, "elapsed_seconds": round(elapsed, 2), "exit_code": result.returncode}


def _write_run_metrics(metrics: list[dict]) -> None:
    """Append pipeline run metrics to a JSON-lines log file."""
    log_dir = _workspace_root() / "Orchestration" / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    log_file = log_dir / "pipeline_metrics.jsonl"
    with open(log_file, "a", encoding="utf-8") as f:
        for m in metrics:
            f.write(json.dumps(m) + "\n")


{% for area in areas %}
@task(name="dlt-extract-{{ area.name }}", retries=2, retry_delay_seconds=60)
def extract_{{ area.name }}(vendor: str) -> dict:
    """Run the DLT extract pipeline for {{ area.title }}."""
    root = _workspace_root()
    script = root / "Pipeline-Casts" / "{{ area.title }}" / vendor / "Data-Extract" / f"{vendor}_pipeline.py"
    return _run(f"{sys.executable} {script}", cwd=root)


@task(name="sqlmesh-transform-{{ area.name }}", retries=1, retry_delay_seconds=30)
def transform_{{ area.name }}(vendor: str) -> dict:
    """Run SQLMesh plan against prod for {{ area.title }}."""
    root = _workspace_root()
    extract_path = root / "Pipeline-Casts" / "{{ area.title }}" / vendor / "Data-Extract"
    pipeline_path = root / "Pipeline-Casts" / "{{ area.title }}" / vendor / "Data-Pipeline"
    log_dir = root / "Orchestration" / "logs"
    _run(
        f"sqlmesh --log-file-dir {log_dir}"
        f" -p {extract_path} -p {pipeline_path}"
        f" migrate",
        cwd=root,
    )
    return _run(
        f"sqlmesh --log-file-dir {log_dir}"
        f" -p {extract_path} -p {pipeline_path}"
        f" plan prod --auto-apply --no-prompts --skip-tests",
        cwd=root,
    )


{% endfor %}
@flow(name="{{ project_slug }}-pipeline", log_prints=True)
def main() -> None:
    parser = argparse.ArgumentParser(description="{{ project_name }} Pipeline")
{% for area in areas %}
    parser.add_argument("--{{ area.name }}-vendor", default="{{ area.software }}", help="{{ area.title }} data vendor")
{% endfor %}
    args = parser.parse_args()

    logger = get_run_logger()
    run_metrics = []
    t0 = time.monotonic()

{% for area in areas %}
    extract_result = extract_{{ area.name }}(args.{{ area.name }}_vendor)
    run_metrics.append({"stage": "extract_{{ area.name }}", **extract_result})
    transform_result = transform_{{ area.name }}(args.{{ area.name }}_vendor)
    run_metrics.append({"stage": "transform_{{ area.name }}", **transform_result})
{% endfor %}

    total_elapsed = round(time.monotonic() - t0, 2)
    logger.info("Pipeline completed in %.2f seconds", total_elapsed)
    _write_run_metrics(run_metrics)


if __name__ == "__main__":
    main()
