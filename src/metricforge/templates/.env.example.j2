# {{ project_name }} — Environment Variables
# Generated by MetricForge Kiln v{{ kiln_version }}
# Copy this file to .env and fill in your credentials.

# ── Project Identity (used for schema/database isolation) ──
PROJECT_NAME={{ project_name }}
PROJECT_SLUG={{ project_slug }}

# ── PostgreSQL (SQLMesh state tracking) ──
SQLMESH_POSTGRES_HOST=localhost
SQLMESH_POSTGRES_PORT=5432
SQLMESH_POSTGRES_USER=sqlmesh
SQLMESH_POSTGRES_PASSWORD=CHANGE_ME
SQLMESH_POSTGRES_DATABASE=sqlmesh_{{ project_slug }}

{% if dw_type == 'motherduck' %}
# ── MotherDuck ──
# Database is scoped to this project: {{ project_slug }}
MD_TOKEN=
MOTHERDUCK_CODESPACE_TOKEN=
MOTHERDUCK_DATABASE={{ project_slug }}
{% endif %}
{% if dw_type == 'snowflake' %}
# ── Snowflake ──
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE={{ project_slug }}
SNOWFLAKE_SCHEMA=PUBLIC
{% endif %}
{% if dw_type == 'bigquery' %}
# ── BigQuery ──
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
GCP_PROJECT_ID=
BIGQUERY_DATASET_PREFIX={{ project_slug }}
{% endif %}
{% if sl_type == 'cube_oss' %}
# ── Cube.js OSS ──
CUBEJS_API_SECRET={{ cube_api_secret }}
CUBEJS_DEV_MODE=true
{% endif %}
{% if sl_type == 'cube_cloud' %}
# ── Cube Cloud ──
CUBE_CLOUD_TOKEN=
CUBE_CLOUD_DEPLOY_ID=
{% endif %}
{% if has_support and support_software == 'zendesk' %}
# ── Zendesk ──
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_TOKEN=
{% endif %}
{% if has_support and support_software == 'salesforce' %}
# ── Salesforce (Support) ──
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
{% endif %}
{% if has_sales and sales_software == 'zendesk' %}
# ── Zendesk (Sales) ──
ZENDESK_SALES_SUBDOMAIN=
ZENDESK_SALES_EMAIL=
ZENDESK_SALES_TOKEN=
{% endif %}
{% if has_sales and sales_software == 'salesforce' %}
# ── Salesforce (Sales) ──
SALESFORCE_SALES_USERNAME=
SALESFORCE_SALES_PASSWORD=
SALESFORCE_SALES_SECURITY_TOKEN=
{% endif %}
