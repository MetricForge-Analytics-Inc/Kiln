# {{ project_name }} — MetricForge Configuration
# Generated by MetricForge Kiln v{{ kiln_version }}

project_name: {{ project_name }}
organization: {{ organization }}
kiln_version: {{ kiln_version }}

# Data Warehouse Configuration
data_warehouse:
  type: {{ dw_type }}
  config:
{% if dw_type == 'duckdb_local' %}
    database_path: ./db/metricforge.duckdb
{% elif dw_type == 'motherduck' %}
    database: {{ project_slug }}
    # motherduck_token: <set MD_TOKEN env var>
{% elif dw_type == 'snowflake' %}
    account: <account>
    user: <username>
    warehouse: COMPUTE_WH
    database: {{ project_slug | upper }}
    schema: PUBLIC
{% elif dw_type == 'bigquery' %}
    project_id: <gcp-project-id>
    dataset_id: {{ project_slug }}
{% endif %}

# Semantic Layer Configuration
semantic_layer:
  type: {{ sl_type }}
  config:
{% if sl_type == 'cube_oss' %}
    port: 4000
    sql_port: 15432
    api_secret: CHANGE_ME
{% elif sl_type == 'cube_cloud' %}
    deploy_id: <deployment-id>
    api_endpoint: https://api.cubecloudapp.com
{% elif sl_type == 'looker' %}
    instance_url: <looker-instance-url>
    client_id: <client-id>
{% elif sl_type == 'metabase' %}
    port: 3000
    admin_email: admin@metricforge.local
{% elif sl_type == 'superset' %}
    port: 8088
    admin_username: admin
{% endif %}

# Feature Flags
include_docker: {{ include_docker | lower }}
include_tests: {{ include_tests | lower }}
include_cicd: {{ include_cicd | lower }}

{% if areas %}
# Pipeline Configuration
pipelines:
{% for area in areas %}
  {{ area.name }}:
    software: {{ area.software }}
{% endfor %}
{% endif %}
