# Docker Compose configuration for {{ cookiecutter.project_name }}
# Generated by MetricForge Crucible

version: '3.8'

services:
{%- if cookiecutter.data_warehouse == 'duckdb_local' %}
  # Local DuckDB volume - optional, for sharing across containers
  # DuckDB file is stored in ./db/metricforge.duckdb on host
{%- endif %}

{%- if cookiecutter.semantic_layer == 'cube_oss' %}
  cube:
    image: cubejs/cube:v1.3
    ports:
      - "4000:4000"     # REST + Playground
      - "15432:15432"   # SQL API (Postgres wire protocol)
    environment:
      # ── Data source ─────────────────────────────────────────────
      CUBEJS_DB_TYPE: duckdb
      CUBEJS_DB_DUCKDB_DATABASE_PATH: /cube/db/metricforge.duckdb
      # ── API settings ────────────────────────────────────────────
      CUBEJS_DEV_MODE: "true"
      CUBEJS_API_SECRET: "{{ cookiecutter.cube_oss_api_secret | default('CHANGE_ME') }}"
      CUBEJS_EXTERNAL_DEFAULT: "true"
      CUBEJS_SCHEMA_PATH: model
      # ── SQL API (Postgres-wire) ─────────────────────────────────
      CUBEJS_PG_SQL_PORT: "15432"
    volumes:
      # Mount cube model definitions
      - ./Foundry-Semantic-Cubes/models:/cube/conf/model:ro
      # Mount the DuckDB file
      - ./db:/cube/db
      # Mount cube.py configuration
      - ./Foundry-Semantic-Cubes/cube.py:/cube/conf/cube.py:ro
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4000/cubejs-api/v1/meta"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - metricforge
{%- endif %}

{%- if cookiecutter.semantic_layer == 'metabase' %}
  postgres:
    image: postgres:15-alpine
    environment:
      POSTGRES_DB: metabase
      POSTGRES_USER: metabase
      POSTGRES_PASSWORD: CHANGE_ME
    volumes:
      - metabase-postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U metabase"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - metricforge

  metabase:
    image: metabase/metabase:latest
    ports:
      - "3000:3000"
    environment:
      MB_DB_TYPE: postgres
      MB_DB_HOST: postgres
      MB_DB_PORT: 5432
      MB_DB_NAME: metabase
      MB_DB_USER: metabase
      MB_DB_PASS: CHANGE_ME
      MB_ADMIN_EMAIL: "{{ cookiecutter.admin_email | default('admin@metricforge.local') }}"
      MB_ADMIN_PASSWORD: "{{ cookiecutter.admin_password | default('changeme') }}"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - metricforge
{%- endif %}

{%- if cookiecutter.semantic_layer == 'superset' %}
  superset:
    image: apache/superset:latest
    ports:
      - "8088:8088"
    environment:
      SUPERSET_ADMIN_USERNAME: "{{ cookiecutter.superset_admin_username | default('admin') }}"
      SUPERSET_ADMIN_PASSWORD: "{{ cookiecutter.superset_admin_password | default('admin') }}"
      SECRET_KEY: "{{ cookiecutter.superset_secret_key | default('CHANGE_ME') }}"
    volumes:
      - ./Foundry-Semantic-Cubes/superset-config:/etc/superset
    networks:
      - metricforge
{%- endif %}

{%- if cookiecutter.semantic_layer in ['metabase', 'superset'] or cookiecutter.data_warehouse in ['snowflake', 'bigquery'] %}

{%- endif %}

networks:
  metricforge:
    driver: bridge

{%- if cookiecutter.semantic_layer == 'metabase' %}
volumes:
  metabase-postgres-data:
{%- endif %}
